{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Projection",
  "description": "Parsed projection scheme as it appears in the surface syntax.",
  "type": "object",
  "properties": {
    "post": {
      "description": "Declared post commands.",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/PostCommand"
      }
    },
    "transaction": {
      "description": "Declared transactions.",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Transaction"
      }
    },
    "transform": {
      "description": "Declared transforms.",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Transform"
      }
    }
  },
  "$defs": {
    "Delimiter": {
      "description": "One delimiter as written in the scheme file.",
      "anyOf": [
        {
          "description": "A literal delimiter matched by exact text.",
          "type": "string"
        },
        {
          "description": "A regular-expression delimiter matched by the Rust regex engine.",
          "$ref": "#/$defs/RegexDelimiter"
        }
      ]
    },
    "Effect": {
      "description": "One effect in surface syntax.",
      "anyOf": [
        {
          "description": "Replaces a matched region with a template string.",
          "type": "object",
          "properties": {
            "replace": {
              "description": "Replacement template.",
              "type": "string"
            }
          },
          "required": [
            "replace"
          ]
        },
        {
          "description": "Logs a matched region or anchor.",
          "type": "object",
          "properties": {
            "log": {
              "description": "Presence marker for the log effect.\n\nNote: The design uses delimiter count to distinguish region and\nanchor logging. The boolean keeps the TOML shape concise:\n`effects = [{ log = true }]`.",
              "type": "boolean"
            }
          },
          "required": [
            "log"
          ]
        }
      ]
    },
    "LogDestination": {
      "description": "Transaction log sink in surface syntax.",
      "anyOf": [
        {
          "description": "Write log records to a file.",
          "type": "string"
        },
        {
          "description": "Write log records to a named pipe target.",
          "$ref": "#/$defs/LogPipe"
        }
      ]
    },
    "LogPipe": {
      "description": "Named log pipe target.",
      "type": "object",
      "properties": {
        "pipe": {
          "description": "Selected pipe target.",
          "$ref": "#/$defs/PipeName"
        }
      },
      "additionalProperties": false,
      "required": [
        "pipe"
      ]
    },
    "PipeName": {
      "description": "Supported log pipe targets.",
      "oneOf": [
        {
          "description": "Standard output stream.",
          "type": "string",
          "const": "stdout"
        }
      ]
    },
    "PostCommand": {
      "description": "Scheme-level post command.",
      "type": "object",
      "properties": {
        "cmd": {
          "description": "Command string executed by the shell.",
          "type": "string"
        },
        "dir": {
          "description": "Working directory for the command.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "dir",
        "cmd"
      ]
    },
    "RegexDelimiter": {
      "description": "Regular-expression delimiter payload.",
      "type": "object",
      "properties": {
        "regex": {
          "description": "Regular-expression source text.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "regex"
      ]
    },
    "Transaction": {
      "description": "One transaction as it appears in the scheme file.",
      "type": "object",
      "properties": {
        "dst": {
          "description": "Optional destination file or destination directory.",
          "type": [
            "string",
            "null"
          ]
        },
        "log": {
          "description": "Optional transaction log sink.",
          "anyOf": [
            {
              "$ref": "#/$defs/LogDestination"
            },
            {
              "type": "null"
            }
          ]
        },
        "pattern": {
          "description": "Optional glob patterns for declared directory transactions.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "src": {
          "description": "Source file or source directory.",
          "type": "string"
        },
        "transform": {
          "description": "Transform names applied to every selected work item.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "src",
        "transform"
      ]
    },
    "Transform": {
      "description": "One named transform in surface syntax.",
      "type": "object",
      "properties": {
        "delimiters": {
          "description": "Delimiters in source order.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Delimiter"
          }
        },
        "effects": {
          "description": "Effects applied to every matched chain.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Effect"
          }
        },
        "name": {
          "description": "User-facing transform identifier.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "delimiters",
        "effects"
      ]
    }
  }
}
