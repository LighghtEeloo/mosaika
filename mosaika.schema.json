{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proj",
  "type": "object",
  "properties": {
    "post": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Command"
      }
    },
    "transaction": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Transaction"
      }
    },
    "transform": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Transform"
      }
    }
  },
  "required": [
    "transform",
    "transaction",
    "post"
  ],
  "$defs": {
    "Action": {
      "type": "object",
      "properties": {
        "replace": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "replace"
      ]
    },
    "Command": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "system": {
              "$ref": "#/$defs/SystemCommand"
            }
          },
          "additionalProperties": false,
          "required": [
            "system"
          ]
        }
      ]
    },
    "Delimiter": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/RegexDelimiter"
        }
      ]
    },
    "RegexDelimiter": {
      "type": "object",
      "properties": {
        "regex": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "regex"
      ]
    },
    "SystemCommand": {
      "type": "object",
      "properties": {
        "cmd": {
          "type": "string"
        },
        "dir": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "dir",
        "cmd"
      ]
    },
    "Transaction": {
      "type": "object",
      "properties": {
        "dst": {
          "type": "string"
        },
        "pattern": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "src": {
          "type": "string"
        },
        "transform": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "src",
        "dst",
        "transform"
      ]
    },
    "Transform": {
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/Action"
        },
        "delimiters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Delimiter"
          }
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "delimiters",
        "action"
      ]
    }
  }
}
